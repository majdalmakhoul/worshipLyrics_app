# Vercel Blob storage
NODE_ENV=production
ADMIN_TOKEN=your-private-admin-password
SONGS_STORAGE=vercel-blob
SONGS_BLOB_PATH=worship-songs.json
SONGS_BLOB_ACCESS=private

# Vercel may add these automatically when the Blob store is connected.
# Use the real values from Vercel only; do not use placeholders.
# BLOB_READ_WRITE_TOKEN=
# BLOB_STORE_ID=

# Local/Azure file storage
# SONGS_STORAGE=file
# SONGS_FILE=/home/data/worship-songs.json
