# Vercel Blob storage
NODE_ENV=production
ADMIN_TOKEN=your-private-admin-password
SONGS_STORAGE=vercel-blob
SONGS_BLOB_PATH=worship-songs.json
SONGS_BLOB_ACCESS=private
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token

